generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Better Auth ────────────────────────────────────────

model User {
  id                String                   @id
  name              String
  email             String
  emailVerified     Boolean                  @default(false)
  image             String?
  isAgent           Boolean                  @default(false)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  sessions          Session[]
  accounts          Account[]
  members           Member[]
  invitations       Invitation[]             @relation("InviterInvitations")
  projects          Project[]
  assignedTasks     Task[]                   @relation("TaskAssignees")
  notes             Note[]
  notifications     Notification[]
  stateTransitions  ProjectStateTransition[]
  taskTransitions   TaskTransition[]
  ideas             Idea[]
  pushSubscriptions PushSubscription[]
  agentTokens       AgentToken[]             @relation("AgentTokenUser")
  createdAgentTokens AgentToken[]            @relation("AgentTokenCreator")
  favoriteProjects  Project[]                @relation("ProjectFavorites")

  @@unique([email])
  @@map("user")
}

model Session {
  id                   String   @id
  expiresAt            DateTime
  token                String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganizationId String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ─── Organizations ──────────────────────────────────────

model Organization {
  id        String   @id
  name      String
  slug      String   @unique
  logo      String?
  metadata  String?
  createdAt DateTime @default(now())

  members     Member[]
  invitations Invitation[]
  projects    Project[]
  ideas       Idea[]
  agentTokens AgentToken[]

  @@map("organization")
}

model Member {
  id             String   @id
  userId         String
  organizationId String
  role           String
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("member")
}

model Invitation {
  id             String   @id
  email          String
  inviterId      String
  organizationId String
  role           String?
  status         String
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  inviter      User         @relation("InviterInvitations", fields: [inviterId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([organizationId])
  @@map("invitation")
}

// ─── Dashboard ──────────────────────────────────────────

model Project {
  id            String       @id @default(cuid())
  title         String
  brainDump     String       @default("")
  artifactLinks String       @default("")
  state         ProjectState @default(Backlog)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  tasks            Task[]
  logs             LogEntry[]
  notes            Note[]
  transitions      ProjectStateTransition[]
  promotedFromIdea Idea?
  favoritedBy      User[]                   @relation("ProjectFavorites")

  @@index([organizationId])
  @@index([userId])
  @@map("project")
}

model ProjectStateTransition {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // null fromState = project creation
  fromState ProjectState?
  toState   ProjectState
  at        DateTime      @default(now())

  // nullable so agent-initiated transitions or backfills can omit an actor
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([projectId, at])
  @@map("project_state_transition")
}

model Task {
  id          String      @id @default(cuid())
  title       String
  description String      @default("")
  columnId    String      @default("todo")
  section     TaskSection @default(Product)
  position    Int         @default(0)

  assignees User[] @relation("TaskAssignees")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  transitions TaskTransition[]

  @@index([projectId])
  @@map("task")
}

model TaskTransition {
  id     String @id @default(cuid())
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // null fromColumnId = task creation
  fromColumnId String?
  toColumnId   String
  at           DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([taskId, at])
  @@map("task_transition")
}

model LogEntry {
  id   String @id @default(cuid())
  text String

  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("log_entry")
}

model Notification {
  id        String   @id @default(cuid())
  type      String // "task_assigned" | "note_mention" | "task_mention" | "log_mention"
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notification")
}

model Note {
  id      String @id @default(cuid())
  title   String @default("")
  content String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  @@index([projectId])
  @@map("note")
}

// ─── Agent Tokens ───────────────────────────────────────

model AgentToken {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Synthetic agent user — every action by this token is attributed here
  agentUserId String @unique
  agentUser   User   @relation("AgentTokenUser", fields: [agentUserId], references: [id], onDelete: Cascade)

  name        String   // human label, e.g. "claude-local"
  tokenHash   String   @unique // sha256 of full token
  tokenPrefix String   // first 12 chars (incl. "ccs_") for UI display
  scopes      String[] // ["org:read","projects:read","projects:write","tasks:read","tasks:write","logs:write"]
  projectIds  String[] @default([]) // empty = all projects in org

  createdByUserId String
  createdBy       User   @relation("AgentTokenCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)

  expiresAt  DateTime?
  revokedAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([organizationId])
  @@map("agent_token")
}

// ─── Push Notifications ─────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("push_subscription")
}

// ─── Idea Bucket ────────────────────────────────────────

model Idea {
  id                     String               @id @default(cuid())
  title                  String
  description            String               @default("")
  links                  String               @default("")
  rawTranscript          String               @default("")
  source                 IdeaSource           @default(Text)
  status                 IdeaStatus           @default(Pending)
  nameSearchStatus       IdeaNameSearchStatus @default(NotStarted)
  nameSearchError        String?
  nameSearchUpdatedAt    DateTime?
  nameSearchCheckedCount Int                  @default(0)
  nameSearchLastDomain   String?

  promotedToProjectId String?  @unique
  promotedToProject   Project? @relation(fields: [promotedToProjectId], references: [id], onDelete: SetNull)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  nameSuggestions IdeaNameSuggestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([userId])
  @@map("idea")
}

model IdeaNameSuggestion {
  id     String @id @default(cuid())
  ideaId String
  idea   Idea   @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  name      String
  domain    String
  rationale String @default("")
  position  Int    @default(0)

  createdAt DateTime @default(now())

  @@unique([ideaId, domain])
  @@index([ideaId, position])
  @@map("idea_name_suggestion")
}

// ─── Enums ──────────────────────────────────────────────

enum ProjectState {
  Backlog
  InBuild @map("In Build")
  Live
  Paused
}

enum TaskSection {
  Product
  Marketing
}

enum IdeaSource {
  Text
  Voice
}

enum IdeaStatus {
  Pending
  Promoted
  Archived
}

enum IdeaNameSearchStatus {
  NotStarted
  Running
  Completed
  Failed
}
